# Copy this file to .env and fill in real values
# NEVER commit the real .env file to GitHub

# GitHub OAuth App credentials (create at github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here

# Generate with: openssl rand -hex 32
JUPYTERHUB_CRYPT_KEY=generate_with_openssl_rand_hex_32
